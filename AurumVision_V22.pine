//@version=5
strategy("Aurum Vision V11 [Ultimate]", overlay=true, initial_capital=1000, default_qty_type=strategy.fixed, default_qty_value=0.1)

// ==================== DEFINICION DE COLORES (Arriba para evitar errores) ====================
c_gold   = color.new(#FFD700, 0)
c_white  = color.white
c_black  = color.black
c_lime   = color.lime
c_green  = color.green
c_red    = color.red
c_gray   = color.gray
c_orange = color.orange

// ==================== INPUTS ====================
grp_strat = "Estrategia Sniper V11"
inp_ma_per    = input.int(200, "Tendencia H1 (EMA)", group=grp_strat) 
inp_zone_dist = input.int(100, "Distancia a Zona H1", group=grp_strat) 
inp_rsi_ob    = input.int(70, "RSI SobreVenta (> Venta)", group=grp_strat)
inp_rsi_os    = input.int(30, "RSI Sobrecompra (< Compra)", group=grp_strat)
inp_adx_min   = input.int(20, "ADX Mínimo", group=grp_strat)
inp_auto_tune = input.bool(true, "Auto-Ajustar por Activo", group=grp_strat)

grp_risk = "Gestión Salida (Simulación)"
inp_rr        = input.float(2.0, "Ratio Riesgo:Beneficio", step=0.1, group=grp_risk)
inp_atr_mult  = input.float(2.0, "Multiplicador SL (x ATR)", step=0.1, group=grp_risk)

// ==================== AUTO-AJUSTE DINÁMICO POR ACTIVO ====================
int zone_dist = inp_zone_dist
int rsi_ob    = inp_rsi_ob
int rsi_os    = inp_rsi_os
int adx_min   = inp_adx_min
float atr_mult = inp_atr_mult

if inp_auto_tune
    string sym = syminfo.ticker
    if str.contains(sym, "EURUSD")
        zone_dist := 100
        rsi_os    := 45
        rsi_ob    := 80
    else if str.contains(sym, "USDJPY")
        zone_dist := 300
        rsi_os    := 40
        rsi_ob    := 60
    else if str.contains(sym, "GBPUSD")
        zone_dist := 150
        rsi_os    := 42
        rsi_ob    := 78
    else if str.contains(sym, "XAUUSD") or str.contains(sym, "GOLD")
        zone_dist := 400
        rsi_os    := 35
        rsi_ob    := 65
        adx_min   := 25
        atr_mult  := 2.5


// ==================== DATOS MULTI-TIMEFRAME ====================
// Extraemos datos de H1 para la Tendencia y las Zonas (Igual que el Bot)
[h1_ema, h1_high_20, h1_low_20] = request.security(syminfo.tickerid, "60", [ta.ema(close, inp_ma_per), ta.highest(high, 20), ta.lowest(low, 20)])

// Datos del Chart Actual (M1 recomendado)
rsi = ta.rsi(close, 14)
[diplus, diminus, adx] = ta.dmi(14, 14)
atr = ta.atr(14)

// ==================== LÓGICA DE FILTROS ====================

// 1. TENDENCIA H1
// El precio actual debe estar alineado con la EMA H1
trend_bull = close > h1_ema
trend_bear = close < h1_ema

// 2. ZONAS DE UN HORA (DINAMICA V11)
// Precio dentro de X distancia de Soportes H1... O rebotando en la EMA (Pullback)
dist_val = zone_dist * syminfo.mintick
in_zone_buy  = (math.abs(close - h1_low_20) <= dist_val) or (math.abs(close - h1_ema) <= dist_val)
in_zone_sell = (math.abs(close - h1_high_20) <= dist_val) or (math.abs(close - h1_ema) <= dist_val)

// 3. FILTRO ANTI-INERCIA (Anti-Spike)
// Detecta si la vela anterior fue 3 veces más grande que el promedio de las anteriores
body = math.abs(close - open)
// Calculamos promedio de cuerpos históricos (velas 4 a 13 atrás, para tener base estable)
avg_body_stable = 0.0
for i = 4 to 13
    avg_body_stable := avg_body_stable + body[i]
avg_body_stable := avg_body_stable / 10

// Evaluamos SOLO la vela anterior (Agilidad V11)
last_body = body[1]
is_spike = last_body > (avg_body_stable * 3.0)

// ==================== PATRONES DE VELA (EDUCATIVO) ====================
// Detecta patrones clásicos para confirmación visual (No bloquea la entrada V11)
is_hammer = (math.min(open, close) >= low + (high-low)*0.7) and (low < math.min(open, close)) // Mecha larga abajo
is_star   = (math.max(open, close) <= low + (high-low)*0.3) and (high > math.max(open, close)) // Mecha larga arriba

is_bull_engulf = close > open and close[1] < open[1] and close > open[1] and open < close[1]
is_bear_engulf = close < open and close[1] > open[1] and close < open[1] and open > close[1]

// ==================== TRAMPAS DE LIQUIDEZ (SMART TRAPS) ====================
// Detecta cuando el precio rompe una zona pero cierra dentro (Fakeout/Rechazo)
trap_bear = low < h1_low_20 and close > h1_low_20 and in_zone_buy // Trampa en Soporte (Bullish)
trap_bull = high > h1_high_20 and close < h1_high_20 and in_zone_sell // Trampa en Resistencia (Bearish)

// Marcamos las trampas históricas en el gráfico para que sean visibles en el Backtest
plotshape(trap_bear, "Trampa Soporte", shape.labelup, location.belowbar, c_lime, text="🪤 Trampa", textcolor=c_black, size=size.tiny)
plotshape(trap_bull, "Trampa Resistencia", shape.labeldown, location.abovebar, c_red, text="🪤 Trampa", textcolor=c_white, size=size.tiny)

// ==================== DISPAROS (TRIGGERS) ====================
// Condiciones exactas del Bot V11 MT5
long_cond_raw = trend_bull and in_zone_buy and rsi < rsi_os and adx > adx_min and not is_spike
short_cond_raw = trend_bear and in_zone_sell and rsi > rsi_ob and adx > adx_min and not is_spike

// Filtrar para evitar sobreposición (Solo 1 trade a la vez, igual que MT5)
long_cond = long_cond_raw and strategy.position_size == 0
short_cond = short_cond_raw and strategy.position_size == 0

// ==================== EJECUCIÓN & VISUALES ====================

// Colores Dinámicos
// NOTA: Usamos las variables c_lime y c_red definidas arriba para evitar error 'Undeclared identifier color'
col_bull = color.new(c_lime, 0)
col_bear = color.new(c_red, 0)

// Pintar EMA H1 (Referencia Visual)
plot(h1_ema, "EMA H1 Trend", color=trend_bull ? col_bull : col_bear, linewidth=2)

// Pintar Zonas H1 (Referencia Spacial)
plot(h1_high_20, "Zona H1 Sell", color=color.new(c_red, 70), linewidth=1, style=plot.style_circles)
plot(h1_low_20, "Zona H1 Buy", color=color.new(c_lime, 70), linewidth=1, style=plot.style_circles)

// --- VISUALIZADOR DE SETUP (SL/TP PROSPECTIVO) ---
// Dibuja las lineas de la ultima señal para ayudar al trader manual
var line ln_sl = na
var line ln_tp = na
var line ln_en = na
var label lbl_info = na

if long_cond or short_cond
    line.delete(ln_sl)
    line.delete(ln_tp)
    line.delete(ln_en)
    label.delete(lbl_info)
    
    float en_price = close
    float atr_val  = atr
    float sl_dist  = atr_val * atr_mult
    float tp_dist  = sl_dist * inp_rr
    
    float sl_price = long_cond ? en_price - sl_dist : en_price + sl_dist
    float tp_price = long_cond ? en_price + tp_dist : en_price - tp_dist
    color sig_col  = long_cond ? c_lime : c_red
    
    // Dibujar Lineas (Extender 15 barras a futuro)
    ln_en := line.new(bar_index, en_price, bar_index + 15, en_price, color=color.new(c_white, 50), style=line.style_dotted)
    ln_sl := line.new(bar_index, sl_price, bar_index + 15, sl_price, color=c_red, width=2)
    ln_tp := line.new(bar_index, tp_price, bar_index + 15, tp_price, color=c_lime, width=2)
    
    // Etiqueta Informativa
    string txt_info = (long_cond ? "BUY" : "SELL") + "\nEntrada: " + str.tostring(en_price) + "\nTP: " + str.tostring(tp_price) + "\nSL: " + str.tostring(sl_price)
    lbl_info := label.new(bar_index + 5, (en_price + tp_price)/2, txt_info, color=color.new(c_black, 100), textcolor=sig_col, style=label.style_label_center, size=size.small)

// ==================== ETIQUETAS EDUCATIVAS (VISUALES) ====================
if barstate.islast
    // Etiqueta EMA
    label.new(bar_index, h1_ema, "EMA H1\n(" + (trend_bull ? "ALCISTA" : "BAJISTA") + ")", color=trend_bull?col_bull:col_bear, style=label.style_label_left, textcolor=c_white)
    
    // Etiquetas Zonas
    label.new(bar_index, h1_high_20, "H1 RESISTENCIA\n(Zona Sell)", color=c_red, style=label.style_label_left, textcolor=c_white)
    label.new(bar_index, h1_low_20, "H1 SOPORTE\n(Zona Buy)", color=c_green, style=label.style_label_left, textcolor=c_white)

// Etiqueta SPIKE (Alerta en velas pasadas)
if is_spike
    label.new(bar_index, high, "⚠️ SPIKE!", color=c_orange, style=label.style_label_down, textcolor=c_white, size=size.tiny)

// Etiquetas Patrones Educativos (Pequeños y sutiles)
if is_hammer and in_zone_buy
    label.new(bar_index, low, "🔨", color=color.new(c_lime, 100), style=label.style_label_up, textcolor=c_lime, size=size.tiny)
if is_star and in_zone_sell
    label.new(bar_index, high, "💫", color=color.new(c_red, 100), style=label.style_label_down, textcolor=c_red, size=size.tiny)
if is_bull_engulf and in_zone_buy
    label.new(bar_index, low, "🔄 Engulf", color=color.new(c_lime, 100), style=label.style_label_up, textcolor=c_lime, size=size.tiny)
if is_bear_engulf and in_zone_sell
    label.new(bar_index, high, "🔄 Engulf", color=color.new(c_red, 100), style=label.style_label_down, textcolor=c_red, size=size.tiny)

// Ejecución de Estrategia (Manejo Exacto de Precios en lugar de Ticks)
if long_cond
    sl_dist = (atr * atr_mult)
    tp_dist = sl_dist * inp_rr
    strategy.entry("Sniper Buy", strategy.long)
    strategy.exit("Exit Buy", "Sniper Buy", stop = close - sl_dist, limit = close + tp_dist)

if short_cond
    sl_dist = (atr * atr_mult)
    tp_dist = sl_dist * inp_rr
    strategy.entry("Sniper Sell", strategy.short)
    strategy.exit("Exit Sell", "Sniper Sell", stop = close + sl_dist, limit = close - tp_dist)

// Señales en Gráfico
plotshape(long_cond, "BUY", shape.triangleup, location.belowbar, col_bull, size=size.small, text="SNIPER-V11")
plotshape(short_cond, "SELL", shape.triangledown, location.abovebar, col_bear, size=size.small, text="SNIPER-V11")

// ==================== DASHBOARD ALUMNOS ====================
var table dash = table.new(position.top_right, 2, 8, bgcolor = color.new(c_black, 40), border_width=1)

if barstate.islast
    table.cell(dash, 0, 0, "🦅 AURUM VISION", text_color=c_gold, text_size=size.normal)
    table.cell(dash, 1, 0, "V11 ULTIMATE", text_color=c_white, text_size=size.normal)

    // Fila 1: RSI
    table.cell(dash, 0, 1, "RSI (M1)", text_color=c_white)
    rsi_col = rsi < rsi_os ? c_lime : rsi > rsi_ob ? c_red : c_gray
    table.cell(dash, 1, 1, str.tostring(rsi, "#.##"), text_color=rsi_col)

    // Fila 2: Tendencia H1
    table.cell(dash, 0, 2, "Trend H1", text_color=c_white)
    table.cell(dash, 1, 2, trend_bull ? "ALCISTA (BUY)" : "BAJISTA (SELL)", text_color= trend_bull ? c_lime : c_red)

    // Fila 3: Filtro Spike
    table.cell(dash, 0, 3, "Anti-Spike", text_color=c_white)
    table.cell(dash, 1, 3, is_spike ? "⚠️ RECHAZADO" : "✅ SEGURO", text_color= is_spike ? c_orange : c_green)

    // Fila 4: Status Zona
    table.cell(dash, 0, 4, "Zona H1", text_color=c_white)
    
    string zone_txt = "NEUTRO"
    color zone_col  = c_gray

    if trend_bull and in_zone_buy
        zone_txt := "ZONA COMPRA"
        zone_col := c_lime
    else if trend_bear and in_zone_sell
        zone_txt := "ZONA VENTA"
        zone_col := c_red
    else if in_zone_buy
        zone_txt := "ZONA COMPRA"
        zone_col := c_lime
    else if in_zone_sell
        zone_txt := "ZONA VENTA"
        zone_col := c_red

    table.cell(dash, 1, 4, zone_txt, text_color=zone_col)

    // Fila 5: ADX (Nuevo V11)
    table.cell(dash, 0, 5, "ADX (" + str.tostring(inp_adx_min) + "+)", text_color=c_white)
    bool adx_ok = adx > inp_adx_min
    table.cell(dash, 1, 5, str.tostring(adx, "#.##") + (adx_ok ? " (ACTIVO)" : " (DORMIDO)"), text_color = adx_ok ? c_lime : c_orange)


