//@version=5
// AURUM VISION [UNIFIED V22]
strategy("Aurum Vision [Unified V22]", overlay=true, initial_capital=100, default_qty_type=strategy.fixed, default_qty_value=0.01)

// INPUTS
group_strat = "Estrategia (Scalping M5)"
inp_dist_points = input.int(50, "Distancia Zona H1 (Puntos)", group=group_strat)
inp_adx_min     = input.int(20, "Filtro Volatilidad ADX (M15)", group=group_strat)
inp_ema_period  = input.int(200, "EMA Tendencia (M15)", group=group_strat)
inp_rsi_period  = input.int(14,  "Periodo RSI", group=group_strat)
inp_rsi_ob      = input.float(75.0, "RSI Venta (>)", group=group_strat)
inp_rsi_os      = input.float(25.0, "RSI Compra (<)", group=group_strat)

// --- INDICATORS ---
// RSI (Current Timeframe M5)
rsi_val = ta.rsi(close, inp_rsi_period)

// M15 Data (Trend + ADX)
[m15_ema, m15_adx] = request.security(syminfo.tickerid, "15", [ta.ema(close, inp_ema_period), ta.dmi(14, 14).adx])

// H1 Data (Zones)
// 20-period High/Low
[h1_high, h1_low] = request.security(syminfo.tickerid, "60", [ta.highest(high, 20), ta.lowest(low, 20)])

// --- LOGIC ---
// Trend Filter
trend_bullish = close > m15_ema
trend_bearish = close < m15_ema

// Zone Filter
dist_price = inp_dist_points * syminfo.mintick
in_buy_zone  = math.abs(close - h1_low) <= dist_price
in_sell_zone = math.abs(close - h1_high) <= dist_price

// --- CANDLE PATTERNS (V9) ---
detect_pattern(type) =>
    body = math.abs(close - open)
    c_range = high - low
    upper_wick = high - math.max(open, close)
    lower_wick = math.min(open, close) - low

    result = false

    if type == "BUY"
        // Hammer: Lower wick >= 2x Body AND Body in upper 30%
        // Upper 30% means math.min(open, close) >= low + (0.7 * c_range)
        is_hammer = (lower_wick >= 2 * body) and (math.min(open, close) >= low + (0.7 * c_range))

        // Bullish Engulfing
        // Previous candle bearish, Current candle bullish
        // Current wraps Previous
        prev_open  = open[1]
        prev_close = close[1]
        is_engulfing = (prev_close < prev_open) and (close > open) and (close > prev_open) and (open < prev_close)

        result := is_hammer or is_engulfing

    if type == "SELL"
        // Shooting Star: Upper wick >= 2x Body AND Body in lower 30%
        // Lower 30% means math.max(open, close) <= low + (0.3 * c_range)
        is_shooting_star = (upper_wick >= 2 * body) and (math.max(open, close) <= low + (0.3 * c_range))

        // Bearish Engulfing
        prev_open  = open[1]
        prev_close = close[1]
        is_engulfing = (prev_close > prev_open) and (close < open) and (close < prev_open) and (open > prev_close)

        result := is_shooting_star or is_engulfing

    result

pattern_buy = detect_pattern("BUY")
pattern_sell = detect_pattern("SELL")

// --- ENTRY CONDITIONS ---
// V8 Logic (Trend + Zone + RSI + ADX) + V9 Logic (Pattern)
longCond = trend_bullish and in_buy_zone and (rsi_val < inp_rsi_os) and (m15_adx > inp_adx_min) and pattern_buy
shortCond = trend_bearish and in_sell_zone and (rsi_val > inp_rsi_ob) and (m15_adx > inp_adx_min) and pattern_sell

if longCond
    strategy.entry("Long", strategy.long)
    alert("BUY Signal: V9 Pattern Detected", alert.freq_once_per_bar_close)

if shortCond
    strategy.entry("Short", strategy.short)
    alert("SELL Signal: V9 Pattern Detected", alert.freq_once_per_bar_close)

// --- VISUALS ---
plotshape(longCond, title="Buy Signal", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(shortCond, title="Sell Signal", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)

// Dashboard
var table dash = table.new(position.top_right, 2, 6, bgcolor = color.new(color.black, 50))
if barstate.islast
    table.cell(dash, 0, 0, "Aurum Vision", text_color=color.gold)
    table.cell(dash, 1, 0, "V22", text_color=color.white)

    table.cell(dash, 0, 1, "RSI (M5)", text_color=color.white)
    table.cell(dash, 1, 1, str.tostring(rsi_val, "#.##"), text_color = rsi_val < inp_rsi_os ? color.green : rsi_val > inp_rsi_ob ? color.red : color.white)

    table.cell(dash, 0, 2, "Trend (M15)", text_color=color.white)
    table.cell(dash, 1, 2, trend_bullish ? "BULL" : "BEAR", text_color = trend_bullish ? color.green : color.red)

    table.cell(dash, 0, 3, "Zone (H1)", text_color=color.white)
    table.cell(dash, 1, 3, in_buy_zone ? "BUY ZONE" : in_sell_zone ? "SELL ZONE" : "NONE", text_color=color.yellow)

    table.cell(dash, 0, 4, "Pattern", text_color=color.white)
    table.cell(dash, 1, 4, pattern_buy ? "BUY PATTERN" : pattern_sell ? "SELL PATTERN" : "WAITING", text_color = pattern_buy ? color.green : pattern_sell ? color.red : color.gray)
